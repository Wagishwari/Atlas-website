# MongoDB Connection (Get free at mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/atlas?retryWrites=true&w=majority

# Email Configuration (Gmail or SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Admin Security Key
ADMIN_KEY=your-super-secret-admin-key-change-this

# Environment
NODE_ENV=production
PORT=3000

# SendGrid Alternative (optional)
# SENDGRID_API_KEY=your-sendgrid-key
